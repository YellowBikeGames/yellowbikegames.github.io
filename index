<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Football Blitz AI</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{

    font-family:Arial,Helvetica,sans-serif;

    height:100vh;

    overflow:hidden;

    display:flex;
    justify-content:center;
    align-items:center;

    background:radial-gradient(circle,#2ed75f 0%,#13963e 45%,#0b6126 100%);
}

body::before{

    content:"";

    position:fixed;
    inset:-50%;

    background:
    repeating-conic-gradient(
        rgba(255,255,255,.03) 0deg,
        rgba(255,255,255,0) 9deg
    );

    animation:spin 45s linear infinite;
}

.container{

    position:relative;

    z-index:2;

    text-align:center;

    padding:30px;

}

.logo{

    width:220px;
    max-width:70vw;

    border-radius:28px;

    box-shadow:
        0 20px 50px rgba(0,0,0,.35);

}

h1{

    color:white;

    margin:35px 0;

    font-size:3rem;

    font-weight:900;

    text-shadow:
        0 5px 20px rgba(0,0,0,.35);

}

.play{

    display:inline-block;

    margin-top:10px;

    padding:18px 36px;

    background:white;

    color:#222;

    text-decoration:none;

    font-weight:bold;

    border-radius:999px;

    transition:.25s;

    box-shadow:
        0 10px 30px rgba(0,0,0,.25);

}

.play:hover{

    transform:translateY(-4px);

    box-shadow:
        0 20px 40px rgba(0,0,0,.35);

}

.redirect{

    color:white;

    opacity:.7;

    margin-top:20px;

}

@keyframes spin{

from{

transform:rotate(0deg);

}

to{

transform:rotate(360deg);

}

}

</style>

</head>

<body>

<div class="container">

<img class="logo" src="logo.png">

<h1>Football Blitz AI</h1>

<a class="play"
href="https://play.google.com/store/apps/details?id=com.yellowbikegames.footballblitzai">
Download on Google Play
</a>

<div class="redirect">
Redirecting...
</div>

</div>

<script>

const url="https://play.google.com/store/apps/details?id=com.yellowbikegames.footballblitzai";

setTimeout(()=>{

window.location.replace(url);

},2000);

</script>

</body>

</html>
